# Copy to .env and fill in real values. .env is gitignored — never commit it.
#
# WARNING: anything prefixed with VITE_ is inlined into the public browser
# bundle at build time. Only put values here that are safe to publish.
# Secrets belong in the sections below, never behind a VITE_ prefix.

# --- Frontend (public, shipped in the bundle) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Local Garmin sync script (scripts/garmin-sync.mjs) ---
# Runs on your machine: Garmin blocks datacenter IPs, so this cannot run in a
# Supabase edge function.
GARMIN_EMAIL=your-garmin-email
GARMIN_PASSWORD=your-garmin-password
# Service role key from the Supabase dashboard (Settings > API). Bypasses RLS.
# Server-side only — never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Supabase Edge Function secrets ---
# Set via the Supabase dashboard (Edge Functions > Secrets), not in this file:
#   ANTHROPIC_API_KEY       food-lookup AI freetext parsing
#   FATSECRET_CLIENT_ID     food database lookups
#   FATSECRET_CLIENT_SECRET
#   STRAVA_CLIENT_ID        cardio activity import
#   STRAVA_CLIENT_SECRET
#   STRAVA_REDIRECT_URI
