VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Set in Supabase Edge Function secrets (not in .env):
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Garmin sync script (scripts/garmin-sync.mjs) — runs locally on a residential IP.
# Garmin blocks datacenter IPs, so this cannot run in a Supabase edge function.
GARMIN_EMAIL=your-garmin-email
GARMIN_PASSWORD=your-garmin-password
# Service role key from Supabase dashboard (Settings > API). Bypasses RLS for writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
